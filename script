// ==UserScript==
// @name         i9educacao - Clique Automático 'Next'
// @namespace    http://tampermonkey.net/
// @version      1.1
// @description  Clica na imagem 'next.svg' a cada 240 segundos
// @author       Seu Nome
// @match        *://*.i9educacao.com/*
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function() {
    'use strict';

    // --- CONFIGURAÇÃO ---

    // Intervalo em milissegundos (240 segundos = 240000 ms)
    const intervalo = 240000;

    // Seletor de CSS CORRIGIDO para a imagem da seta "Próxima aula"
    const seletorDoElemento = "img[alt='Avançar'][src='/assets/icons/next.svg']";

    // --- FIM DA CONFIGURAÇÃO ---

    console.log("Script 'i9educacao - Clique Automático' CARREGADO.");

    // Função que procura e clica no elemento
    function clicarNoElemento() {

        // Encontra o elemento na página usando o seletor CSS
        const elemento = document.querySelector(seletorDoElemento);

        // Verifica se o elemento foi encontrado
        if (elemento) {
            console.log("Elemento 'next.svg' encontrado. Clicando...");
            elemento.click();
        } else {
            console.log("Elemento 'next.svg' não encontrado. Aguardando a próxima tentativa...");
        }
    }

    // Inicia o temporizador que executa a função repetidamente
    setInterval(clicarNoElemento, intervalo);

})();
